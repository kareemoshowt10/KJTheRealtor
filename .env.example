# KJ Lead-Gen Agency — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# Google Maps (for Scout)
GOOGLE_MAPS_API_KEY=

# AI (for Diagnoser, Checker, Mobile) — Gemini 2.5 Pro/Flash
# Get a free key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Lovable (for Builder mockup generation)
LOVABLE_API_KEY=

# Higgsfield (for Filmer video creation)
HIGGSFIELD_API_KEY=

# Screenshot API (for Filmer screenshots)
SCREENSHOTONE_API_KEY=

# SendGrid (for email pitches)
SENDGRID_API_KEY=

# Twilio (for SMS pitches)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+18184027326

# Instagram (for DM pitches — use session cookie from logged-in browser)
INSTAGRAM_SESSION_ID=

# LinkedIn (for LinkedIn message pitches)
LINKEDIN_ACCESS_TOKEN=

# Calendly (for Mobile booking)
CALENDLY_API_KEY=
CALENDLY_EVENT_TYPE_UUID=
