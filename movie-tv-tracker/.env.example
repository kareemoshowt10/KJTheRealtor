# Firebase client SDK config (Project settings → General → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK service account (Project settings → Service accounts →
# Generate new private key). Paste the private_key value as-is; the code
# converts literal "\n" sequences to real newlines.
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

TMDB_API_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
