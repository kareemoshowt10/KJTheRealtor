{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/93063",
      "destination": "https://kj-the-realtor-93063-lead-gen.vercel.app/"
    },
    {
      "source": "/93063/:match*",
      "destination": "https://kj-the-realtor-93063-lead-gen.vercel.app/:match*"
    }
  ],
  "redirects": [
    {
      "source": "/buyers-and-sellers",
      "destination": "/buyers",
      "permanent": true
    },
    {
      "source": "/buyers-and-sellers.html",
      "destination": "/buyers",
      "permanent": true
    },
    {
      "source": "/faq-section",
      "destination": "/buyers#faq",
      "permanent": true
    },
    {
      "source": "/faq-section.html",
      "destination": "/buyers#faq",
      "permanent": true
    },
    {
      "source": "/west-hills-realtor",
      "destination": "/west-hills",
      "permanent": true
    },
    {
      "source": "/west-hills-realtor.html",
      "destination": "/west-hills",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' * data: 'unsafe-inline' 'unsafe-eval';"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
