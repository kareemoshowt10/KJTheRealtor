rules_version = '2';

// Every read/write in this app goes through the Next.js server using the
// Firebase Admin SDK, which bypasses these rules entirely (it has full
// trusted access regardless of what's written here). The client SDK is
// used only for Firebase Auth (email-link sign-in) — it never touches
// Firestore directly. These rules exist purely as defense in depth, in
// case a client ever tries to read/write Firestore directly with the
// public web SDK: deny everything.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
